@page "/sales"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject ApiService Api

<PageTitle>Sales</PageTitle>

<TabContainer Tabs="tabs" ActiveTab="@activeTab" OnTabChanged="async t => { activeTab = t; await LoadTab(); }" />

<div class="bg-white rounded-b-lg border border-t-0 border-gray-200 p-4">
    @switch (activeTab)
    {
        case "Customers":
            <PageHeader Title="Customers" Subtitle="Manage your customer accounts.">
                <Breadcrumb><span>/ Sales / <strong>Customers</strong></span></Breadcrumb>
                <Actions>
                    <button @onclick="() => ShowCustomerModal()" class="px-4 py-2 bg-indigo-600 text-white rounded-lg text-sm font-medium hover:bg-indigo-700 flex items-center gap-2">
                        <span class="material-icons-outlined text-sm">add</span> New Customer
                    </button>
                </Actions>
            </PageHeader>
            <div class="flex flex-wrap gap-2 mb-4">
                <input @bind="search" @bind:event="oninput" @onkeyup="OnSearch" placeholder="Search customers..." class="px-3 py-2 border border-gray-300 rounded-lg text-sm w-full sm:w-64" />
                <button @onclick="LoadCustomers" class="px-3 py-2 border border-gray-300 rounded-lg text-sm hover:bg-gray-50">
                    <span class="material-icons-outlined text-sm">refresh</span>
                </button>
            </div>
            @if (customers?.Items is not null)
            {
                <div class="overflow-x-auto">
                    <table class="w-full min-w-[700px]">
                        <thead>
                            <tr class="text-left text-xs text-gray-500 uppercase border-b border-gray-200">
                                <th class="px-4 py-3">Code</th>
                                <th class="px-4 py-3">Name</th>
                                <th class="px-4 py-3">Email</th>
                                <th class="px-4 py-3">Phone</th>
                                <th class="px-4 py-3">City</th>
                                <th class="px-4 py-3">Total Sales</th>
                                <th class="px-4 py-3">Orders</th>
                                <th class="px-4 py-3">Status</th>
                                <th class="px-4 py-3"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var c in customers.Items)
                            {
                                <tr class="border-b border-gray-50 hover:bg-gray-50">
                                    <td class="px-4 py-3 text-sm font-mono font-bold text-indigo-600">@c.Code</td>
                                    <td class="px-4 py-3 text-sm font-medium">@c.Name</td>
                                    <td class="px-4 py-3 text-sm text-gray-500">@c.Email</td>
                                    <td class="px-4 py-3 text-sm text-gray-500">@c.Phone</td>
                                    <td class="px-4 py-3 text-sm">@c.City</td>
                                    <td class="px-4 py-3 text-sm font-mono font-semibold">@c.TotalSales.ToString("C0")</td>
                                    <td class="px-4 py-3 text-sm text-center">@c.OrderCount</td>
                                    <td class="px-4 py-3">
                                        <span class="px-2 py-0.5 rounded text-xs @(c.IsActive ? "bg-green-100 text-green-700" : "bg-gray-100 text-gray-500")">@(c.IsActive ? "Active" : "Inactive")</span>
                                    </td>
                                    <td class="px-4 py-3">
                                        <button @onclick="() => ShowCustomerModal(c)" class="text-gray-400 hover:text-indigo-600">
                                            <span class="material-icons-outlined text-sm">edit</span>
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <Pagination Page="customerPage" PageSize="customerPageSize" TotalCount="customers.TotalCount"
                            PageChanged="async p => { customerPage = p; await LoadCustomers(); }"
                            PageSizeChanged="async s => { customerPageSize = s; customerPage = 1; await LoadCustomers(); }" />
            }
            else
            {
                <div class="flex items-center justify-center h-32"><div class="animate-spin rounded-full h-8 w-8 border-b-2 border-indigo-600"></div></div>
            }
            break;

        case "Quotes":
            <PageHeader Title="Quotations" Subtitle="Manage sales quotations.">
                <Breadcrumb><span>/ Sales / <strong>Quotes</strong></span></Breadcrumb>
                <Actions>
                    <button @onclick="() => ShowQuoteModal()" class="px-4 py-2 bg-indigo-600 text-white rounded-lg text-sm font-medium hover:bg-indigo-700 flex items-center gap-2">
                        <span class="material-icons-outlined text-sm">add</span> New Quote
                    </button>
                </Actions>
            </PageHeader>
            @if (quotes?.Items is not null)
            {
                <div class="overflow-x-auto">
                    <table class="w-full min-w-[700px]">
                        <thead>
                            <tr class="text-left text-xs text-gray-500 uppercase border-b border-gray-200">
                                <th class="px-4 py-3">Quote #</th>
                                <th class="px-4 py-3">Customer</th>
                                <th class="px-4 py-3">Date</th>
                                <th class="px-4 py-3">Expiry</th>
                                <th class="px-4 py-3">Total</th>
                                <th class="px-4 py-3">Status</th>
                                <th class="px-4 py-3"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var q in quotes.Items)
                            {
                                <tr class="border-b border-gray-50 hover:bg-gray-50">
                                    <td class="px-4 py-3 text-sm font-mono font-bold text-indigo-600">@q.QuoteNumber</td>
                                    <td class="px-4 py-3 text-sm font-medium">@q.CustomerName</td>
                                    <td class="px-4 py-3 text-sm">@q.QuoteDate.ToString("MMM dd, yyyy")</td>
                                    <td class="px-4 py-3 text-sm text-gray-500">@(q.ExpiryDate?.ToString("MMM dd, yyyy") ?? "—")</td>
                                    <td class="px-4 py-3 text-sm font-mono font-semibold">@q.TotalAmount.ToString("C2")</td>
                                    <td class="px-4 py-3">
                                        <span class="px-2 py-0.5 rounded text-xs font-medium @QuoteStatusColor(q.Status.ToString())">@q.Status</span>
                                    </td>
                                    <td class="px-4 py-3">
                                        <button @onclick="() => ShowQuoteModal(q)" class="text-gray-400 hover:text-indigo-600">
                                            <span class="material-icons-outlined text-sm">edit</span>
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <Pagination Page="quotePage" PageSize="quotePageSize" TotalCount="quotes.TotalCount"
                            PageChanged="async p => { quotePage = p; await LoadQuotes(); }"
                            PageSizeChanged="async s => { quotePageSize = s; quotePage = 1; await LoadQuotes(); }" />
            }
            else
            {
                <div class="flex items-center justify-center h-32"><div class="animate-spin rounded-full h-8 w-8 border-b-2 border-indigo-600"></div></div>
            }
            break;

        case "Orders":
            <PageHeader Title="Sales Orders" Subtitle="Track sales orders and fulfillment.">
                <Breadcrumb><span>/ Sales / <strong>Orders</strong></span></Breadcrumb>
                <Actions>
                    <button @onclick="() => ShowOrderModal()" class="px-4 py-2 bg-indigo-600 text-white rounded-lg text-sm font-medium hover:bg-indigo-700 flex items-center gap-2">
                        <span class="material-icons-outlined text-sm">add</span> New Order
                    </button>
                </Actions>
            </PageHeader>
            @if (salesOrders?.Items is not null)
            {
                <div class="overflow-x-auto">
                    <table class="w-full min-w-[700px]">
                        <thead>
                            <tr class="text-left text-xs text-gray-500 uppercase border-b border-gray-200">
                                <th class="px-4 py-3">Order #</th>
                                <th class="px-4 py-3">Customer</th>
                                <th class="px-4 py-3">Order Date</th>
                                <th class="px-4 py-3">Required By</th>
                                <th class="px-4 py-3">Total</th>
                                <th class="px-4 py-3">Status</th>
                                <th class="px-4 py-3"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var o in salesOrders.Items)
                            {
                                <tr class="border-b border-gray-50 hover:bg-gray-50">
                                    <td class="px-4 py-3 text-sm font-mono font-bold text-indigo-600">@o.OrderNumber</td>
                                    <td class="px-4 py-3 text-sm font-medium">@o.CustomerName</td>
                                    <td class="px-4 py-3 text-sm">@o.OrderDate.ToString("MMM dd, yyyy")</td>
                                    <td class="px-4 py-3 text-sm text-gray-500">@(o.RequiredDate?.ToString("MMM dd, yyyy") ?? "—")</td>
                                    <td class="px-4 py-3 text-sm font-mono font-semibold">@o.TotalAmount.ToString("C2")</td>
                                    <td class="px-4 py-3">
                                        <span class="px-2 py-0.5 rounded text-xs font-medium @OrderStatusColor(o.Status.ToString())">@o.Status</span>
                                    </td>
                                    <td class="px-4 py-3">
                                        <button @onclick="() => ShowOrderModal(o)" class="text-gray-400 hover:text-indigo-600">
                                            <span class="material-icons-outlined text-sm">edit</span>
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <Pagination Page="orderPage" PageSize="orderPageSize" TotalCount="salesOrders.TotalCount"
                            PageChanged="async p => { orderPage = p; await LoadSalesOrders(); }"
                            PageSizeChanged="async s => { orderPageSize = s; orderPage = 1; await LoadSalesOrders(); }" />
            }
            else
            {
                <div class="flex items-center justify-center h-32"><div class="animate-spin rounded-full h-8 w-8 border-b-2 border-indigo-600"></div></div>
            }
            break;

        case "Invoices":
            <PageHeader Title="Sales Invoices" Subtitle="Customer invoices and payment collection.">
                <Breadcrumb><span>/ Sales / <strong>Invoices</strong></span></Breadcrumb>
                <Actions>
                    <button @onclick="() => ShowInvoiceModal()" class="px-4 py-2 bg-indigo-600 text-white rounded-lg text-sm font-medium hover:bg-indigo-700 flex items-center gap-2">
                        <span class="material-icons-outlined text-sm">add</span> New Invoice
                    </button>
                </Actions>
            </PageHeader>
            @if (salesInvoices?.Items is not null)
            {
                <div class="overflow-x-auto">
                    <table class="w-full min-w-[800px]">
                        <thead>
                            <tr class="text-left text-xs text-gray-500 uppercase border-b border-gray-200">
                                <th class="px-4 py-3">Invoice #</th>
                                <th class="px-4 py-3">Customer</th>
                                <th class="px-4 py-3">Invoice Date</th>
                                <th class="px-4 py-3">Due Date</th>
                                <th class="px-4 py-3">Total</th>
                                <th class="px-4 py-3">Paid</th>
                                <th class="px-4 py-3">Balance</th>
                                <th class="px-4 py-3">Status</th>
                                <th class="px-4 py-3"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var inv in salesInvoices.Items)
                            {
                                <tr class="border-b border-gray-50 hover:bg-gray-50">
                                    <td class="px-4 py-3 text-sm font-mono font-bold text-indigo-600">@inv.InvoiceNumber</td>
                                    <td class="px-4 py-3 text-sm font-medium">@inv.CustomerName</td>
                                    <td class="px-4 py-3 text-sm">@inv.InvoiceDate.ToString("MMM dd, yyyy")</td>
                                    <td class="px-4 py-3 text-sm @(inv.DueDate < DateTime.Now && inv.Status.ToString() != "Paid" ? "text-red-600 font-medium" : "")">@inv.DueDate.ToString("MMM dd, yyyy")</td>
                                    <td class="px-4 py-3 text-sm font-mono">@inv.TotalAmount.ToString("C2")</td>
                                    <td class="px-4 py-3 text-sm font-mono text-green-600">@inv.PaidAmount.ToString("C2")</td>
                                    <td class="px-4 py-3 text-sm font-mono font-bold @(inv.BalanceDue > 0 ? "text-red-600" : "text-green-600")">@inv.BalanceDue.ToString("C2")</td>
                                    <td class="px-4 py-3">
                                        <span class="px-2 py-0.5 rounded text-xs font-medium @InvoiceStatusColor(inv.Status.ToString())">@inv.Status</span>
                                    </td>
                                    <td class="px-4 py-3">
                                        <button @onclick="() => ShowInvoiceModal(inv)" class="text-gray-400 hover:text-indigo-600">
                                            <span class="material-icons-outlined text-sm">edit</span>
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <Pagination Page="invPage" PageSize="invPageSize" TotalCount="salesInvoices.TotalCount"
                            PageChanged="async p => { invPage = p; await LoadSalesInvoices(); }"
                            PageSizeChanged="async s => { invPageSize = s; invPage = 1; await LoadSalesInvoices(); }" />
            }
            else
            {
                <div class="flex items-center justify-center h-32"><div class="animate-spin rounded-full h-8 w-8 border-b-2 border-indigo-600"></div></div>
            }
            break;
    }
</div>

@* Customer Modal *@
<Modal IsVisible="showCustomerModal" Title='@(editCustomer?.Id > 0 ? "Edit Customer" : "New Customer")' OnClose="() => showCustomerModal = false">
    <ChildContent>
    @if (editCustomer is not null)
    {
        <div class="space-y-4">
            <div class="grid grid-cols-2 gap-3">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Code</label>
                    <input @bind="editCustomer.Code" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm font-mono" placeholder="CUST-001" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Payment Terms</label>
                    <select @bind="editCustomer.PaymentTerms" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm">
                        <option>Net 30</option><option>Net 15</option><option>Net 60</option><option>Due on Receipt</option>
                    </select>
                </div>
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Customer Name</label>
                <input @bind="editCustomer.Name" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" />
            </div>
            <div class="grid grid-cols-2 gap-3">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Email</label>
                    <input @bind="editCustomer.Email" type="email" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Phone</label>
                    <input @bind="editCustomer.Phone" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" />
                </div>
            </div>
            <div class="grid grid-cols-2 gap-3">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">City</label>
                    <input @bind="editCustomer.City" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Country</label>
                    <input @bind="editCustomer.Country" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" />
                </div>
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Credit Limit</label>
                <input type="number" @bind="editCustomer.CreditLimit" step="100" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" />
            </div>
        </div>
    }
    </ChildContent>
    <Footer>
        <button @onclick="SaveCustomer" class="px-4 py-2 bg-indigo-600 text-white rounded-lg text-sm font-medium hover:bg-indigo-700">Save</button>
        <button @onclick="() => showCustomerModal = false" class="px-4 py-2 border border-gray-300 rounded-lg text-sm hover:bg-gray-50">Cancel</button>
    </Footer>
</Modal>

@* Quote Modal *@
<Modal IsVisible="showQuoteModal" Title='@(editQuote?.Id > 0 ? "Edit Quote" : "New Quote")' OnClose="() => showQuoteModal = false">
    <ChildContent>
    @if (editQuote is not null)
    {
        <div class="space-y-4">
            <div class="grid grid-cols-2 gap-3">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Quote Number</label>
                    <input @bind="editQuote.QuoteNumber" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm font-mono" placeholder="QT-0001" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Status</label>
                    <select @bind="editQuote.StatusStr" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm">
                        <option value="Draft">Draft</option>
                        <option value="Sent">Sent</option>
                        <option value="Accepted">Accepted</option>
                        <option value="Rejected">Rejected</option>
                        <option value="Expired">Expired</option>
                    </select>
                </div>
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Customer</label>
                <select @bind="editQuote.CustomerId" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm">
                    <option value="0">— Select Customer —</option>
                    @if (allCustomers is not null)
                    {
                        @foreach (var cust in allCustomers)
                        {
                            <option value="@cust.Id">@cust.Name</option>
                        }
                    }
                </select>
            </div>
            <div class="grid grid-cols-2 gap-3">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Quote Date</label>
                    <input type="date" @bind="editQuote.QuoteDate" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Expiry Date</label>
                    <input type="date" @bind="editQuote.ExpiryDate" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" />
                </div>
            </div>
            <div class="grid grid-cols-3 gap-3">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Sub Total</label>
                    <input type="number" step="0.01" @bind="editQuote.SubTotal" @bind:after="RecalcQuoteTotal" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Tax Amount</label>
                    <input type="number" step="0.01" @bind="editQuote.TaxAmount" @bind:after="RecalcQuoteTotal" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Discount Amount</label>
                    <input type="number" step="0.01" @bind="editQuote.DiscountAmount" @bind:after="RecalcQuoteTotal" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" />
                </div>
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Total Amount</label>
                <input type="number" step="0.01" @bind="editQuote.TotalAmount" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm bg-gray-50" />
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Notes</label>
                <textarea @bind="editQuote.Notes" rows="3" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm"></textarea>
            </div>
        </div>
    }
    </ChildContent>
    <Footer>
        <button @onclick="SaveQuote" class="px-4 py-2 bg-indigo-600 text-white rounded-lg text-sm font-medium hover:bg-indigo-700">Save</button>
        <button @onclick="() => showQuoteModal = false" class="px-4 py-2 border border-gray-300 rounded-lg text-sm hover:bg-gray-50">Cancel</button>
    </Footer>
</Modal>

@* Sales Order Modal *@
<Modal IsVisible="showOrderModal" Title='@(editOrder?.Id > 0 ? "Edit Sales Order" : "New Sales Order")' OnClose="() => showOrderModal = false">
    <ChildContent>
    @if (editOrder is not null)
    {
        <div class="space-y-4">
            <div class="grid grid-cols-2 gap-3">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Order Number</label>
                    <input @bind="editOrder.OrderNumber" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm font-mono" placeholder="SO-0001" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Status</label>
                    <select @bind="editOrder.StatusStr" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm">
                        <option value="Draft">Draft</option>
                        <option value="Confirmed">Confirmed</option>
                        <option value="Processing">Processing</option>
                        <option value="Shipped">Shipped</option>
                        <option value="Delivered">Delivered</option>
                        <option value="Cancelled">Cancelled</option>
                    </select>
                </div>
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Customer</label>
                <select @bind="editOrder.CustomerId" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm">
                    <option value="0">— Select Customer —</option>
                    @if (allCustomers is not null)
                    {
                        @foreach (var cust in allCustomers)
                        {
                            <option value="@cust.Id">@cust.Name</option>
                        }
                    }
                </select>
            </div>
            <div class="grid grid-cols-2 gap-3">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Order Date</label>
                    <input type="date" @bind="editOrder.OrderDate" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Required Date</label>
                    <input type="date" @bind="editOrder.RequiredDate" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" />
                </div>
            </div>
            <div class="grid grid-cols-3 gap-3">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Sub Total</label>
                    <input type="number" step="0.01" @bind="editOrder.SubTotal" @bind:after="RecalcOrderTotal" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Tax Amount</label>
                    <input type="number" step="0.01" @bind="editOrder.TaxAmount" @bind:after="RecalcOrderTotal" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Discount Amount</label>
                    <input type="number" step="0.01" @bind="editOrder.DiscountAmount" @bind:after="RecalcOrderTotal" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" />
                </div>
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Total Amount</label>
                <input type="number" step="0.01" @bind="editOrder.TotalAmount" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm bg-gray-50" />
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Ship To Address</label>
                <input @bind="editOrder.ShipToAddress" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" placeholder="Shipping address..." />
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Notes</label>
                <textarea @bind="editOrder.Notes" rows="3" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm"></textarea>
            </div>
        </div>
    }
    </ChildContent>
    <Footer>
        <button @onclick="SaveOrder" class="px-4 py-2 bg-indigo-600 text-white rounded-lg text-sm font-medium hover:bg-indigo-700">Save</button>
        <button @onclick="() => showOrderModal = false" class="px-4 py-2 border border-gray-300 rounded-lg text-sm hover:bg-gray-50">Cancel</button>
    </Footer>
</Modal>

@* Sales Invoice Modal *@
<Modal IsVisible="showInvoiceModal" Title='@(editInvoice?.Id > 0 ? "Edit Invoice" : "New Invoice")' OnClose="() => showInvoiceModal = false">
    <ChildContent>
    @if (editInvoice is not null)
    {
        <div class="space-y-4">
            <div class="grid grid-cols-2 gap-3">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Invoice Number</label>
                    <input @bind="editInvoice.InvoiceNumber" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm font-mono" placeholder="INV-0001" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Status</label>
                    <select @bind="editInvoice.StatusStr" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm">
                        <option value="Draft">Draft</option>
                        <option value="Sent">Sent</option>
                        <option value="Paid">Paid</option>
                        <option value="PartiallyPaid">Partially Paid</option>
                        <option value="Overdue">Overdue</option>
                        <option value="Cancelled">Cancelled</option>
                    </select>
                </div>
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Customer</label>
                <select @bind="editInvoice.CustomerId" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm">
                    <option value="0">— Select Customer —</option>
                    @if (allCustomers is not null)
                    {
                        @foreach (var cust in allCustomers)
                        {
                            <option value="@cust.Id">@cust.Name</option>
                        }
                    }
                </select>
            </div>
            <div class="grid grid-cols-2 gap-3">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Invoice Date</label>
                    <input type="date" @bind="editInvoice.InvoiceDate" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Due Date</label>
                    <input type="date" @bind="editInvoice.DueDate" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" />
                </div>
            </div>
            <div class="grid grid-cols-3 gap-3">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Sub Total</label>
                    <input type="number" step="0.01" @bind="editInvoice.SubTotal" @bind:after="RecalcInvoiceTotal" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Tax Amount</label>
                    <input type="number" step="0.01" @bind="editInvoice.TaxAmount" @bind:after="RecalcInvoiceTotal" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Discount Amount</label>
                    <input type="number" step="0.01" @bind="editInvoice.DiscountAmount" @bind:after="RecalcInvoiceTotal" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" />
                </div>
            </div>
            <div class="grid grid-cols-2 gap-3">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Total Amount</label>
                    <input type="number" step="0.01" @bind="editInvoice.TotalAmount" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm bg-gray-50" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Paid Amount</label>
                    <input type="number" step="0.01" @bind="editInvoice.PaidAmount" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" />
                </div>
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Notes</label>
                <textarea @bind="editInvoice.Notes" rows="3" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm"></textarea>
            </div>
        </div>
    }
    </ChildContent>
    <Footer>
        <button @onclick="SaveInvoice" class="px-4 py-2 bg-indigo-600 text-white rounded-lg text-sm font-medium hover:bg-indigo-700">Save</button>
        <button @onclick="() => showInvoiceModal = false" class="px-4 py-2 border border-gray-300 rounded-lg text-sm hover:bg-gray-50">Cancel</button>
    </Footer>
</Modal>

@code {
    private string activeTab = "Customers";
    private readonly Dictionary<string, string> tabs = new()
    {
        ["Customers"] = "people",
        ["Quotes"]    = "request_quote",
        ["Orders"]    = "shopping_bag",
        ["Invoices"]  = "receipt"
    };

    // ── Customers ──────────────────────────────────────────────────────────
    private PagedResult<CustomerDto>? customers;
    private string search = "";
    private int customerPage = 1, customerPageSize = 10;
    private bool showCustomerModal;
    private CustomerEditModel? editCustomer;

    // ── Quotes ─────────────────────────────────────────────────────────────
    private PagedResult<QuoteDto>? quotes;
    private int quotePage = 1, quotePageSize = 10;
    private bool showQuoteModal;
    private QuoteEditModel? editQuote;

    // ── Sales Orders ───────────────────────────────────────────────────────
    private PagedResult<SalesOrderDto>? salesOrders;
    private int orderPage = 1, orderPageSize = 10;
    private bool showOrderModal;
    private SalesOrderEditModel? editOrder;

    // ── Sales Invoices ─────────────────────────────────────────────────────
    private PagedResult<SalesInvoiceDto>? salesInvoices;
    private int invPage = 1, invPageSize = 10;
    private bool showInvoiceModal;
    private SalesInvoiceEditModel? editInvoice;

    // ── Shared ─────────────────────────────────────────────────────────────
    private List<CustomerDto>? allCustomers;

    protected override async Task OnInitializedAsync()
    {
        await Task.WhenAll(LoadTab(), LoadAllCustomers());
    }

    private async Task LoadTab()
    {
        switch (activeTab)
        {
            case "Customers": await LoadCustomers(); break;
            case "Quotes":    await LoadQuotes(); break;
            case "Orders":    await LoadSalesOrders(); break;
            case "Invoices":  await LoadSalesInvoices(); break;
        }
    }

    private async Task LoadAllCustomers()
    {
        var r = await Api.GetAsync<ApiResponse<List<CustomerDto>>>("/api/customers/all");
        allCustomers = r?.Data;
    }

    private async Task LoadCustomers()
    {
        var r = await Api.GetAsync<ApiResponse<PagedResult<CustomerDto>>>($"/api/customers?page={customerPage}&pageSize={customerPageSize}&search={search}");
        customers = r?.Data;
    }

    private async Task LoadQuotes()
    {
        var r = await Api.GetAsync<ApiResponse<PagedResult<QuoteDto>>>($"/api/quotes?page={quotePage}&pageSize={quotePageSize}");
        quotes = r?.Data;
    }

    private async Task LoadSalesOrders()
    {
        var r = await Api.GetAsync<ApiResponse<PagedResult<SalesOrderDto>>>($"/api/sales-orders?page={orderPage}&pageSize={orderPageSize}");
        salesOrders = r?.Data;
    }

    private async Task LoadSalesInvoices()
    {
        var r = await Api.GetAsync<ApiResponse<PagedResult<SalesInvoiceDto>>>($"/api/sales-invoices?page={invPage}&pageSize={invPageSize}");
        salesInvoices = r?.Data;
    }

    private void OnSearch(KeyboardEventArgs e) { if (e.Key == "Enter") _ = LoadCustomers(); }

    // ── Customer modal ─────────────────────────────────────────────────────
    private void ShowCustomerModal(CustomerDto? c = null)
    {
        editCustomer = c is null ? new CustomerEditModel() : new CustomerEditModel { Id = c.Id, Code = c.Code, Name = c.Name, Email = c.Email, Phone = c.Phone, City = c.City, Country = c.Country, PaymentTerms = c.PaymentTerms, CreditLimit = c.CreditLimit };
        showCustomerModal = true;
    }

    private async Task SaveCustomer()
    {
        if (editCustomer is null) return;
        var dto = new CustomerDto { Id = editCustomer.Id, Code = editCustomer.Code, Name = editCustomer.Name, Email = editCustomer.Email, Phone = editCustomer.Phone, City = editCustomer.City, Country = editCustomer.Country, PaymentTerms = editCustomer.PaymentTerms, CreditLimit = editCustomer.CreditLimit, IsActive = true };
        if (editCustomer.Id == 0) await Api.PostAsync<CustomerDto, ApiResponse<CustomerDto>>("/api/customers", dto);
        else await Api.PutAsync<CustomerDto, ApiResponse<CustomerDto>>($"/api/customers/{editCustomer.Id}", dto);
        showCustomerModal = false;
        await LoadCustomers();
    }

    // ── Quote modal ────────────────────────────────────────────────────────
    private void ShowQuoteModal(QuoteDto? q = null)
    {
        editQuote = q is null
            ? new QuoteEditModel { QuoteDate = DateTime.Today, ExpiryDate = DateTime.Today.AddDays(30), StatusStr = "Draft" }
            : new QuoteEditModel
            {
                Id             = q.Id,
                QuoteNumber    = q.QuoteNumber,
                CustomerId     = q.CustomerId,
                QuoteDate      = q.QuoteDate,
                ExpiryDate     = q.ExpiryDate,
                SubTotal       = q.SubTotal,
                TaxAmount      = q.TaxAmount,
                DiscountAmount = q.DiscountAmount,
                TotalAmount    = q.TotalAmount,
                StatusStr      = q.Status.ToString(),
                Notes          = q.Notes
            };
        showQuoteModal = true;
    }

    private void RecalcQuoteTotal()
    {
        if (editQuote is null) return;
        editQuote.TotalAmount = editQuote.SubTotal + editQuote.TaxAmount - editQuote.DiscountAmount;
    }

    private async Task SaveQuote()
    {
        if (editQuote is null) return;
        var dto = new QuoteDto
        {
            Id             = editQuote.Id,
            QuoteNumber    = editQuote.QuoteNumber ?? "",
            CustomerId     = editQuote.CustomerId,
            QuoteDate      = editQuote.QuoteDate,
            ExpiryDate     = editQuote.ExpiryDate,
            SubTotal       = editQuote.SubTotal,
            TaxAmount      = editQuote.TaxAmount,
            DiscountAmount = editQuote.DiscountAmount,
            TotalAmount    = editQuote.TotalAmount,
            Notes          = editQuote.Notes
        };
        if (Enum.TryParse<QuoteStatus>(editQuote.StatusStr, out var status)) dto.Status = status;
        if (editQuote.Id == 0) await Api.PostAsync<QuoteDto, ApiResponse<QuoteDto>>("/api/quotes", dto);
        else await Api.PutAsync<QuoteDto, ApiResponse<QuoteDto>>($"/api/quotes/{editQuote.Id}", dto);
        showQuoteModal = false;
        await LoadQuotes();
    }

    // ── Sales Order modal ──────────────────────────────────────────────────
    private void ShowOrderModal(SalesOrderDto? o = null)
    {
        editOrder = o is null
            ? new SalesOrderEditModel { OrderDate = DateTime.Today, RequiredDate = DateTime.Today.AddDays(7), StatusStr = "Draft" }
            : new SalesOrderEditModel
            {
                Id             = o.Id,
                OrderNumber    = o.OrderNumber,
                CustomerId     = o.CustomerId,
                OrderDate      = o.OrderDate,
                RequiredDate   = o.RequiredDate,
                SubTotal       = o.SubTotal,
                TaxAmount      = o.TaxAmount,
                DiscountAmount = o.DiscountAmount,
                TotalAmount    = o.TotalAmount,
                StatusStr      = o.Status.ToString(),
                ShipToAddress  = o.ShipToAddress,
                Notes          = o.Notes
            };
        showOrderModal = true;
    }

    private void RecalcOrderTotal()
    {
        if (editOrder is null) return;
        editOrder.TotalAmount = editOrder.SubTotal + editOrder.TaxAmount - editOrder.DiscountAmount;
    }

    private async Task SaveOrder()
    {
        if (editOrder is null) return;
        var dto = new SalesOrderDto
        {
            Id             = editOrder.Id,
            OrderNumber    = editOrder.OrderNumber ?? "",
            CustomerId     = editOrder.CustomerId,
            OrderDate      = editOrder.OrderDate,
            RequiredDate   = editOrder.RequiredDate,
            SubTotal       = editOrder.SubTotal,
            TaxAmount      = editOrder.TaxAmount,
            DiscountAmount = editOrder.DiscountAmount,
            TotalAmount    = editOrder.TotalAmount,
            ShipToAddress  = editOrder.ShipToAddress,
            Notes          = editOrder.Notes
        };
        if (Enum.TryParse<SalesOrderStatus>(editOrder.StatusStr, out var status)) dto.Status = status;
        if (editOrder.Id == 0) await Api.PostAsync<SalesOrderDto, ApiResponse<SalesOrderDto>>("/api/sales-orders", dto);
        else await Api.PutAsync<SalesOrderDto, ApiResponse<SalesOrderDto>>($"/api/sales-orders/{editOrder.Id}", dto);
        showOrderModal = false;
        await LoadSalesOrders();
    }

    // ── Sales Invoice modal ────────────────────────────────────────────────
    private void ShowInvoiceModal(SalesInvoiceDto? inv = null)
    {
        editInvoice = inv is null
            ? new SalesInvoiceEditModel { InvoiceDate = DateTime.Today, DueDate = DateTime.Today.AddDays(30), StatusStr = "Draft" }
            : new SalesInvoiceEditModel
            {
                Id             = inv.Id,
                InvoiceNumber  = inv.InvoiceNumber,
                CustomerId     = inv.CustomerId,
                InvoiceDate    = inv.InvoiceDate,
                DueDate        = inv.DueDate,
                SubTotal       = inv.SubTotal,
                TaxAmount      = inv.TaxAmount,
                DiscountAmount = inv.DiscountAmount,
                TotalAmount    = inv.TotalAmount,
                PaidAmount     = inv.PaidAmount,
                StatusStr      = inv.Status.ToString(),
                Notes          = inv.Notes
            };
        showInvoiceModal = true;
    }

    private void RecalcInvoiceTotal()
    {
        if (editInvoice is null) return;
        editInvoice.TotalAmount = editInvoice.SubTotal + editInvoice.TaxAmount - editInvoice.DiscountAmount;
    }

    private async Task SaveInvoice()
    {
        if (editInvoice is null) return;
        var dto = new SalesInvoiceDto
        {
            Id             = editInvoice.Id,
            InvoiceNumber  = editInvoice.InvoiceNumber ?? "",
            CustomerId     = editInvoice.CustomerId,
            InvoiceDate    = editInvoice.InvoiceDate,
            DueDate        = editInvoice.DueDate,
            SubTotal       = editInvoice.SubTotal,
            TaxAmount      = editInvoice.TaxAmount,
            DiscountAmount = editInvoice.DiscountAmount,
            TotalAmount    = editInvoice.TotalAmount,
            PaidAmount     = editInvoice.PaidAmount,
            Notes          = editInvoice.Notes
        };
        if (Enum.TryParse<SalesInvoiceStatus>(editInvoice.StatusStr, out var status)) dto.Status = status;
        // No PUT endpoint for invoices — create only
        await Api.PostAsync<SalesInvoiceDto, ApiResponse<SalesInvoiceDto>>("/api/sales-invoices", dto);
        showInvoiceModal = false;
        await LoadSalesInvoices();
    }

    // ── Status badge helpers ───────────────────────────────────────────────
    private static string QuoteStatusColor(string s) => s switch
    {
        "Accepted"  => "bg-green-100 text-green-700",
        "Sent"      => "bg-blue-100 text-blue-700",
        "Rejected"  => "bg-red-100 text-red-600",
        "Expired"   => "bg-orange-100 text-orange-700",
        "Draft"     => "bg-gray-100 text-gray-500",
        _           => "bg-gray-100 text-gray-600"
    };

    private static string OrderStatusColor(string s) => s switch
    {
        "Delivered"  => "bg-green-100 text-green-700",
        "Shipped"    => "bg-blue-100 text-blue-700",
        "Processing" => "bg-indigo-100 text-indigo-700",
        "Confirmed"  => "bg-teal-100 text-teal-700",
        "Draft"      => "bg-gray-100 text-gray-500",
        "Cancelled"  => "bg-red-100 text-red-600",
        _            => "bg-gray-100 text-gray-600"
    };

    private static string InvoiceStatusColor(string s) => s switch
    {
        "Paid"          => "bg-green-100 text-green-700",
        "PartiallyPaid" => "bg-yellow-100 text-yellow-700",
        "Sent"          => "bg-blue-100 text-blue-700",
        "Overdue"       => "bg-red-100 text-red-700",
        "Cancelled"     => "bg-gray-100 text-gray-500",
        "Draft"         => "bg-gray-100 text-gray-500",
        _               => "bg-gray-100 text-gray-600"
    };

    // ── Edit models ────────────────────────────────────────────────────────
    private class CustomerEditModel
    {
        public int Id { get; set; }
        public string? Code { get; set; }
        public string Name { get; set; } = "";
        public string? Email { get; set; }
        public string? Phone { get; set; }
        public string? City { get; set; }
        public string? Country { get; set; }
        public string? PaymentTerms { get; set; } = "Net 30";
        public decimal CreditLimit { get; set; }
    }

    private class QuoteEditModel
    {
        public int Id { get; set; }
        public string? QuoteNumber { get; set; }
        public int CustomerId { get; set; }
        public DateTime QuoteDate { get; set; } = DateTime.Today;
        public DateTime? ExpiryDate { get; set; }
        public decimal SubTotal { get; set; }
        public decimal TaxAmount { get; set; }
        public decimal DiscountAmount { get; set; }
        public decimal TotalAmount { get; set; }
        public string StatusStr { get; set; } = "Draft";
        public string? Notes { get; set; }
    }

    private class SalesOrderEditModel
    {
        public int Id { get; set; }
        public string? OrderNumber { get; set; }
        public int CustomerId { get; set; }
        public DateTime OrderDate { get; set; } = DateTime.Today;
        public DateTime? RequiredDate { get; set; }
        public decimal SubTotal { get; set; }
        public decimal TaxAmount { get; set; }
        public decimal DiscountAmount { get; set; }
        public decimal TotalAmount { get; set; }
        public string StatusStr { get; set; } = "Draft";
        public string? ShipToAddress { get; set; }
        public string? Notes { get; set; }
    }

    private class SalesInvoiceEditModel
    {
        public int Id { get; set; }
        public string? InvoiceNumber { get; set; }
        public int CustomerId { get; set; }
        public DateTime InvoiceDate { get; set; } = DateTime.Today;
        public DateTime DueDate { get; set; } = DateTime.Today.AddDays(30);
        public decimal SubTotal { get; set; }
        public decimal TaxAmount { get; set; }
        public decimal DiscountAmount { get; set; }
        public decimal TotalAmount { get; set; }
        public decimal PaidAmount { get; set; }
        public string StatusStr { get; set; } = "Draft";
        public string? Notes { get; set; }
    }
}
