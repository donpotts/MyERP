@page "/reports"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject ApiService Api

<PageTitle>Reports</PageTitle>

<TabContainer Tabs="tabs" ActiveTab="@activeTab" OnTabChanged="async t => { activeTab = t; await LoadTab(); }" />

<div class="bg-white rounded-b-lg border border-t-0 border-gray-200 p-4 sm:p-6">
    @switch (activeTab)
    {
        case "Financial":
            <PageHeader Title="Financial Reports" Subtitle="Income statement, balance sheet, and cash flow." />
            @if (financial is not null)
            {
                @* P&L Summary *@
                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
                    <div class="bg-indigo-50 border border-indigo-100 rounded-xl p-4">
                        <p class="text-xs font-medium text-indigo-600 uppercase tracking-wide">Total Revenue</p>
                        <p class="text-2xl font-bold text-indigo-800 mt-1">@financial.TotalRevenue.ToString("C0")</p>
                    </div>
                    <div class="bg-red-50 border border-red-100 rounded-xl p-4">
                        <p class="text-xs font-medium text-red-600 uppercase tracking-wide">Total Expenses</p>
                        <p class="text-2xl font-bold text-red-800 mt-1">@financial.TotalExpenses.ToString("C0")</p>
                    </div>
                    <div class="bg-green-50 border border-green-100 rounded-xl p-4">
                        <p class="text-xs font-medium text-green-600 uppercase tracking-wide">Net Profit</p>
                        <p class="text-2xl font-bold text-green-800 mt-1">@financial.NetProfit.ToString("C0")</p>
                    </div>
                    <div class="bg-blue-50 border border-blue-100 rounded-xl p-4">
                        <p class="text-xs font-medium text-blue-600 uppercase tracking-wide">Profit Margin</p>
                        <p class="text-2xl font-bold text-blue-800 mt-1">@financial.ProfitMargin.ToString("F1")%</p>
                    </div>
                </div>

                @* Monthly Chart *@
                <div class="mb-6">
                    <h3 class="text-sm font-semibold text-gray-700 uppercase mb-4">Monthly Revenue & Expenses</h3>
                    <div class="space-y-2">
                        @{
                            var maxVal = financial.RevenueChart.Any() ? financial.RevenueChart.Max(p => Math.Max((double)p.Revenue, (double)p.Expenses)) : 1;
                        }
                        @foreach (var point in financial.RevenueChart)
                        {
                            <div class="flex items-center gap-3">
                                <span class="text-xs text-gray-500 w-8">@point.Month</span>
                                <div class="flex-1 space-y-1">
                                    <div class="flex items-center gap-2">
                                        <div class="flex-1 bg-gray-100 rounded-full h-2.5">
                                            <div class="bg-indigo-500 h-2.5 rounded-full" style="width: @(maxVal > 0 ? (double)point.Revenue * 100 / maxVal : 0)%"></div>
                                        </div>
                                        <span class="text-xs text-gray-500 w-20 text-right">@point.Revenue.ToString("C0")</span>
                                    </div>
                                    <div class="flex items-center gap-2">
                                        <div class="flex-1 bg-gray-100 rounded-full h-1.5">
                                            <div class="bg-red-400 h-1.5 rounded-full" style="width: @(maxVal > 0 ? (double)point.Expenses * 100 / maxVal : 0)%"></div>
                                        </div>
                                        <span class="text-xs text-gray-400 w-20 text-right">@point.Expenses.ToString("C0")</span>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                    <div class="flex gap-4 mt-3 text-xs text-gray-500">
                        <span class="flex items-center gap-1.5"><span class="w-3 h-2.5 bg-indigo-500 rounded-sm inline-block"></span> Revenue</span>
                        <span class="flex items-center gap-1.5"><span class="w-3 h-1.5 bg-red-400 rounded-sm inline-block"></span> Expenses</span>
                    </div>
                </div>

                @* AR / AP *@
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                    <div class="bg-gray-50 rounded-xl p-4 border border-gray-200">
                        <h4 class="text-sm font-semibold text-gray-700 mb-3">Accounts Receivable Aging</h4>
                        <div class="space-y-2">
                            <div class="flex justify-between text-sm"><span class="text-gray-600">Current</span><span class="font-semibold text-green-600">@financial.AccountsReceivable.ToString("C0")</span></div>
                        </div>
                    </div>
                    <div class="bg-gray-50 rounded-xl p-4 border border-gray-200">
                        <h4 class="text-sm font-semibold text-gray-700 mb-3">Accounts Payable Aging</h4>
                        <div class="space-y-2">
                            <div class="flex justify-between text-sm"><span class="text-gray-600">Current</span><span class="font-semibold text-red-600">@financial.AccountsPayable.ToString("C0")</span></div>
                        </div>
                    </div>
                </div>
            }
            else
            {
                <div class="flex items-center justify-center h-32"><div class="animate-spin rounded-full h-8 w-8 border-b-2 border-indigo-600"></div></div>
            }
            break;

        case "Sales":
            <PageHeader Title="Sales Reports" Subtitle="Revenue by product, customer, and region." />
            @if (salesReport is not null)
            {
                <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-6">
                    <div class="bg-green-50 border border-green-100 rounded-xl p-4">
                        <p class="text-xs font-medium text-green-600 uppercase">Total Revenue</p>
                        <p class="text-2xl font-bold text-green-800 mt-1">@salesReport.TotalRevenue.ToString("C0")</p>
                    </div>
                    <div class="bg-blue-50 border border-blue-100 rounded-xl p-4">
                        <p class="text-xs font-medium text-blue-600 uppercase">Total Orders</p>
                        <p class="text-2xl font-bold text-blue-800 mt-1">@salesReport.TotalOrders</p>
                    </div>
                    <div class="bg-purple-50 border border-purple-100 rounded-xl p-4">
                        <p class="text-xs font-medium text-purple-600 uppercase">New Customers</p>
                        <p class="text-2xl font-bold text-purple-800 mt-1">@salesReport.NewCustomers</p>
                    </div>
                </div>

                <h3 class="text-sm font-semibold text-gray-700 uppercase mb-4">Top Products by Revenue</h3>
                <div class="overflow-x-auto">
                    <table class="w-full min-w-[500px]">
                        <thead>
                            <tr class="text-left text-xs text-gray-500 uppercase border-b border-gray-200">
                                <th class="px-4 py-3">Product</th>
                                <th class="px-4 py-3">Qty Sold</th>
                                <th class="px-4 py-3">Revenue</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var p in salesReport.TopProducts)
                            {
                                <tr class="border-b border-gray-50 hover:bg-gray-50">
                                    <td class="px-4 py-3 text-sm font-medium">@p.ProductName</td>
                                    <td class="px-4 py-3 text-sm font-mono">@p.QuantitySold.ToString("N0")</td>
                                    <td class="px-4 py-3 text-sm font-mono font-semibold text-green-600">@p.Revenue.ToString("C2")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="flex items-center justify-center h-32"><div class="animate-spin rounded-full h-8 w-8 border-b-2 border-indigo-600"></div></div>
            }
            break;

        case "Inventory":
            <PageHeader Title="Inventory Reports" Subtitle="Stock valuation, movements, and low stock alerts." />
            @if (inventoryReport is not null)
            {
                <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-6">
                    <div class="bg-teal-50 border border-teal-100 rounded-xl p-4">
                        <p class="text-xs font-medium text-teal-600 uppercase">Inventory Value</p>
                        <p class="text-2xl font-bold text-teal-800 mt-1">@inventoryReport.InventoryValue.ToString("C0")</p>
                    </div>
                    <div class="bg-red-50 border border-red-100 rounded-xl p-4">
                        <p class="text-xs font-medium text-red-600 uppercase">Low Stock Items</p>
                        <p class="text-2xl font-bold text-red-800 mt-1">@inventoryReport.LowStockItems</p>
                    </div>
                    <div class="bg-gray-50 border border-gray-200 rounded-xl p-4">
                        <p class="text-xs font-medium text-gray-600 uppercase">Total Products</p>
                        <p class="text-2xl font-bold text-gray-800 mt-1">@inventoryReport.TotalProducts</p>
                    </div>
                </div>
                <p class="text-sm text-gray-500 text-center py-8">Detailed stock movement reports available — use the Inventory module to view stock levels and movements.</p>
            }
            else
            {
                <div class="flex items-center justify-center h-32"><div class="animate-spin rounded-full h-8 w-8 border-b-2 border-indigo-600"></div></div>
            }
            break;

        case "Projects":
            <PageHeader Title="Project Reports" Subtitle="Project performance, time tracking, and billing." />
            @if (projectReport is not null)
            {
                <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-6">
                    <div class="bg-indigo-50 border border-indigo-100 rounded-xl p-4">
                        <p class="text-xs font-medium text-indigo-600 uppercase">Active Projects</p>
                        <p class="text-2xl font-bold text-indigo-800 mt-1">@projectReport.ActiveProjects</p>
                    </div>
                    <div class="bg-green-50 border border-green-100 rounded-xl p-4">
                        <p class="text-xs font-medium text-green-600 uppercase">Hours Logged</p>
                        <p class="text-2xl font-bold text-green-800 mt-1">@projectReport.TotalHours.ToString("F0")h</p>
                    </div>
                    <div class="bg-blue-50 border border-blue-100 rounded-xl p-4">
                        <p class="text-xs font-medium text-blue-600 uppercase">Billable Revenue</p>
                        <p class="text-2xl font-bold text-blue-800 mt-1">@projectReport.BillableRevenue.ToString("C0")</p>
                    </div>
                </div>
                <p class="text-sm text-gray-500 text-center py-8">Detailed project reports available — use the Projects module to view timesheets and milestones.</p>
            }
            else
            {
                <div class="flex items-center justify-center h-32"><div class="animate-spin rounded-full h-8 w-8 border-b-2 border-indigo-600"></div></div>
            }
            break;
    }
</div>

@code {
    private string activeTab = "Financial";
    private readonly Dictionary<string, string> tabs = new()
    {
        ["Financial"] = "account_balance",
        ["Sales"]     = "trending_up",
        ["Inventory"] = "inventory",
        ["Projects"]  = "bar_chart"
    };

    private ErpDashboardData? financial;
    private ErpDashboardData? salesReport;
    private InventoryReportData? inventoryReport;
    private ProjectReportData? projectReport;

    protected override async Task OnInitializedAsync() => await LoadTab();

    private async Task LoadTab()
    {
        switch (activeTab)
        {
            case "Financial": await LoadFinancial(); break;
            case "Sales":     await LoadSales(); break;
            case "Inventory": await LoadInventory(); break;
            case "Projects":  await LoadProjects(); break;
        }
    }

    private async Task LoadFinancial()
    {
        var r = await Api.GetAsync<ApiResponse<ErpDashboardData>>("/api/reports/financial");
        financial = r?.Data;
    }

    private async Task LoadSales()
    {
        var r = await Api.GetAsync<ApiResponse<ErpDashboardData>>("/api/reports/sales");
        salesReport = r?.Data;
    }

    private async Task LoadInventory()
    {
        var r = await Api.GetAsync<ApiResponse<InventoryReportData>>("/api/reports/inventory");
        inventoryReport = r?.Data;
    }

    private async Task LoadProjects()
    {
        var r = await Api.GetAsync<ApiResponse<ProjectReportData>>("/api/reports/projects");
        projectReport = r?.Data;
    }

    // Local report data classes
    private class InventoryReportData
    {
        public decimal InventoryValue { get; set; }
        public int LowStockItems { get; set; }
        public int TotalProducts { get; set; }
    }

    private class ProjectReportData
    {
        public int ActiveProjects { get; set; }
        public decimal TotalHours { get; set; }
        public decimal BillableRevenue { get; set; }
    }
}
