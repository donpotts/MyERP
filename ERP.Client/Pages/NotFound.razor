@page "/not-found"
@layout MainLayout
@inject NavigationManager Nav

<div class="flex items-center justify-center py-20 px-4">
    <div class="text-center max-w-md">
        <div class="text-8xl font-black text-indigo-200 mb-4 select-none">404</div>
        <h1 class="text-2xl font-bold text-gray-800 mb-2">Page Not Found</h1>
        <p class="text-gray-500 mb-6">The page you're looking for doesn't exist or has been moved.</p>
        <button class="inline-flex items-center gap-2 px-5 py-2.5 bg-indigo-600 text-white text-sm font-medium rounded-lg hover:bg-indigo-700 transition-colors"
                @onclick='() => Nav.NavigateTo("/")'>
            <span class="material-icons-outlined text-base">home</span>
            Back to Dashboard
        </button>
    </div>
</div>
