@page "/crm"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject ApiService Api

<PageTitle>CRM</PageTitle>

<TabContainer Tabs="tabs" ActiveTab="@activeTab" OnTabChanged="async t => { activeTab = t; await LoadTab(); }" />

<div class="bg-white rounded-b-lg border border-t-0 border-gray-200 p-4">
    @switch (activeTab)
    {
        case "Leads":
            <PageHeader Title="Leads" Subtitle="Track and qualify potential customers.">
                <Breadcrumb><span>/ CRM / <strong>Leads</strong></span></Breadcrumb>
                <Actions>
                    <button @onclick="() => ShowLeadModal()" class="px-4 py-2 bg-indigo-600 text-white rounded-lg text-sm font-medium hover:bg-indigo-700 flex items-center gap-2">
                        <span class="material-icons-outlined text-sm">add</span> New Lead
                    </button>
                </Actions>
            </PageHeader>
            <div class="flex flex-wrap gap-2 mb-4">
                <input @bind="search" @bind:event="oninput" @onkeyup="OnSearch" placeholder="Search leads..." class="px-3 py-2 border border-gray-300 rounded-lg text-sm w-full sm:w-64" />
                <button @onclick="LoadLeads" class="px-3 py-2 border border-gray-300 rounded-lg text-sm hover:bg-gray-50">
                    <span class="material-icons-outlined text-sm">refresh</span>
                </button>
            </div>
            @if (leads?.Items is not null)
            {
                <div class="overflow-x-auto">
                    <table class="w-full min-w-[700px]">
                        <thead>
                            <tr class="text-left text-xs text-gray-500 uppercase border-b border-gray-200">
                                <th class="px-4 py-3">Name</th>
                                <th class="px-4 py-3">Company</th>
                                <th class="px-4 py-3">Email</th>
                                <th class="px-4 py-3">Source</th>
                                <th class="px-4 py-3">Est. Value</th>
                                <th class="px-4 py-3">Owner</th>
                                <th class="px-4 py-3">Status</th>
                                <th class="px-4 py-3"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var l in leads.Items)
                            {
                                <tr class="border-b border-gray-50 hover:bg-gray-50">
                                    <td class="px-4 py-3 text-sm font-medium">@l.FullName</td>
                                    <td class="px-4 py-3 text-sm text-gray-500">@(l.Company ?? "—")</td>
                                    <td class="px-4 py-3 text-sm text-gray-500">@(l.Email ?? "—")</td>
                                    <td class="px-4 py-3">
                                        <span class="px-2 py-0.5 rounded text-xs bg-gray-100 text-gray-600">@l.Source</span>
                                    </td>
                                    <td class="px-4 py-3 text-sm font-mono">@(l.EstimatedValue.HasValue ? l.EstimatedValue.Value.ToString("C0") : "—")</td>
                                    <td class="px-4 py-3 text-sm text-gray-500">@(l.OwnerName ?? "—")</td>
                                    <td class="px-4 py-3">
                                        <span class="px-2 py-0.5 rounded text-xs font-medium @LeadStatusColor(l.Status.ToString())">@l.Status</span>
                                    </td>
                                    <td class="px-4 py-3">
                                        <button @onclick="() => ShowLeadModal(l)" class="text-gray-400 hover:text-indigo-600">
                                            <span class="material-icons-outlined text-sm">edit</span>
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <Pagination Page="leadPage" PageSize="leadPageSize" TotalCount="leads.TotalCount"
                            PageChanged="async p => { leadPage = p; await LoadLeads(); }"
                            PageSizeChanged="async s => { leadPageSize = s; leadPage = 1; await LoadLeads(); }" />
            }
            else
            {
                <div class="flex items-center justify-center h-32"><div class="animate-spin rounded-full h-8 w-8 border-b-2 border-indigo-600"></div></div>
            }
            break;

        case "Contacts":
            <PageHeader Title="Contacts" Subtitle="Your business contacts and relationships.">
                <Breadcrumb><span>/ CRM / <strong>Contacts</strong></span></Breadcrumb>
                <Actions>
                    <button @onclick="() => ShowContactModal()" class="px-4 py-2 bg-indigo-600 text-white rounded-lg text-sm font-medium hover:bg-indigo-700 flex items-center gap-2">
                        <span class="material-icons-outlined text-sm">add</span> New Contact
                    </button>
                </Actions>
            </PageHeader>
            @if (contacts?.Items is not null)
            {
                <div class="overflow-x-auto">
                    <table class="w-full min-w-[700px]">
                        <thead>
                            <tr class="text-left text-xs text-gray-500 uppercase border-b border-gray-200">
                                <th class="px-4 py-3">Name</th>
                                <th class="px-4 py-3">Job Title</th>
                                <th class="px-4 py-3">Company</th>
                                <th class="px-4 py-3">Email</th>
                                <th class="px-4 py-3">Phone</th>
                                <th class="px-4 py-3">City</th>
                                <th class="px-4 py-3"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var c in contacts.Items)
                            {
                                <tr class="border-b border-gray-50 hover:bg-gray-50">
                                    <td class="px-4 py-3">
                                        <div class="flex items-center gap-2">
                                            <div class="w-8 h-8 rounded-full bg-indigo-100 flex items-center justify-center text-indigo-700 text-xs font-bold flex-shrink-0">
                                                @c.FirstName.FirstOrDefault()@c.LastName?.FirstOrDefault()
                                            </div>
                                            <span class="text-sm font-medium">@c.FullName</span>
                                        </div>
                                    </td>
                                    <td class="px-4 py-3 text-sm text-gray-500">@(c.JobTitle ?? "—")</td>
                                    <td class="px-4 py-3 text-sm">@(c.Company ?? "—")</td>
                                    <td class="px-4 py-3 text-sm text-gray-500">@(c.Email ?? "—")</td>
                                    <td class="px-4 py-3 text-sm text-gray-500">@(c.Phone ?? "—")</td>
                                    <td class="px-4 py-3 text-sm">@(c.City ?? "—")</td>
                                    <td class="px-4 py-3">
                                        <button @onclick="() => ShowContactModal(c)" class="text-gray-400 hover:text-indigo-600">
                                            <span class="material-icons-outlined text-sm">edit</span>
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <Pagination Page="contactPage" PageSize="contactPageSize" TotalCount="contacts.TotalCount"
                            PageChanged="async p => { contactPage = p; await LoadContacts(); }"
                            PageSizeChanged="async s => { contactPageSize = s; contactPage = 1; await LoadContacts(); }" />
            }
            else
            {
                <div class="flex items-center justify-center h-32"><div class="animate-spin rounded-full h-8 w-8 border-b-2 border-indigo-600"></div></div>
            }
            break;

        case "Opportunities":
            <PageHeader Title="Opportunities" Subtitle="Track and close sales opportunities.">
                <Breadcrumb><span>/ CRM / <strong>Opportunities</strong></span></Breadcrumb>
                <Actions>
                    <button @onclick="() => ShowOpportunityModal()" class="px-4 py-2 bg-indigo-600 text-white rounded-lg text-sm font-medium hover:bg-indigo-700 flex items-center gap-2">
                        <span class="material-icons-outlined text-sm">add</span> New Opportunity
                    </button>
                </Actions>
            </PageHeader>
            @if (opportunities?.Items is not null)
            {
                <div class="overflow-x-auto">
                    <table class="w-full min-w-[700px]">
                        <thead>
                            <tr class="text-left text-xs text-gray-500 uppercase border-b border-gray-200">
                                <th class="px-4 py-3">Opportunity</th>
                                <th class="px-4 py-3">Customer</th>
                                <th class="px-4 py-3">Amount</th>
                                <th class="px-4 py-3">Probability</th>
                                <th class="px-4 py-3">Expected Revenue</th>
                                <th class="px-4 py-3">Close Date</th>
                                <th class="px-4 py-3">Stage</th>
                                <th class="px-4 py-3"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var o in opportunities.Items)
                            {
                                <tr class="border-b border-gray-50 hover:bg-gray-50">
                                    <td class="px-4 py-3 text-sm font-medium">@o.Name</td>
                                    <td class="px-4 py-3 text-sm text-gray-500">@(o.CustomerName ?? o.ContactName ?? "—")</td>
                                    <td class="px-4 py-3 text-sm font-mono font-semibold">@o.Amount.ToString("C0")</td>
                                    <td class="px-4 py-3 text-sm text-center">@o.Probability.ToString("F0")%</td>
                                    <td class="px-4 py-3 text-sm font-mono text-green-600">@o.ExpectedRevenue.ToString("C0")</td>
                                    <td class="px-4 py-3 text-sm text-gray-500">@(o.CloseDate?.ToString("MMM dd, yyyy") ?? "—")</td>
                                    <td class="px-4 py-3">
                                        <span class="px-2 py-0.5 rounded text-xs font-medium @OpportunityStageColor(o.Stage.ToString())">@o.Stage</span>
                                    </td>
                                    <td class="px-4 py-3">
                                        <button @onclick="() => ShowOpportunityModal(o)" class="text-gray-400 hover:text-indigo-600">
                                            <span class="material-icons-outlined text-sm">edit</span>
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <Pagination Page="oppPage" PageSize="oppPageSize" TotalCount="opportunities.TotalCount"
                            PageChanged="async p => { oppPage = p; await LoadOpportunities(); }"
                            PageSizeChanged="async s => { oppPageSize = s; oppPage = 1; await LoadOpportunities(); }" />
            }
            else
            {
                <div class="flex items-center justify-center h-32"><div class="animate-spin rounded-full h-8 w-8 border-b-2 border-indigo-600"></div></div>
            }
            break;

        case "Pipeline":
            <PageHeader Title="Sales Pipeline" Subtitle="Visual overview of your sales pipeline." />
            @if (pipeline is not null)
            {
                <div class="flex gap-4 overflow-x-auto pb-4">
                    @foreach (var stage in pipeline)
                    {
                        <div class="flex-shrink-0 w-64">
                            <div class="flex items-center justify-between mb-3">
                                <span class="text-sm font-semibold text-gray-700">@stage.Stage</span>
                                <span class="text-xs bg-gray-100 text-gray-600 px-2 py-0.5 rounded-full">@stage.Count</span>
                            </div>
                            <div class="text-xs text-gray-500 mb-3">@stage.TotalAmount.ToString("C0")</div>
                            <div class="space-y-2">
                                @foreach (var opp in stage.Opportunities.Take(5))
                                {
                                    <div class="bg-white border border-gray-200 rounded-lg p-3 hover:border-indigo-200 transition shadow-sm">
                                        <p class="text-sm font-medium text-gray-800 truncate">@opp.Name</p>
                                        <p class="text-xs text-gray-500 mt-0.5">@(opp.CustomerName ?? opp.ContactName ?? "—")</p>
                                        <div class="flex items-center justify-between mt-2">
                                            <span class="text-xs font-semibold text-indigo-600">@opp.Amount.ToString("C0")</span>
                                            <span class="text-xs text-gray-400">@opp.Probability.ToString("F0")%</span>
                                        </div>
                                    </div>
                                }
                                @if (stage.Count > 5)
                                {
                                    <p class="text-xs text-center text-gray-400 py-2">+@(stage.Count - 5) more</p>
                                }
                            </div>
                        </div>
                    }
                </div>
            }
            break;
    }
</div>

@* Lead Modal *@
<Modal IsVisible="showLeadModal" Title='@(editLead?.Id > 0 ? "Edit Lead" : "New Lead")' OnClose="() => showLeadModal = false">
    <ChildContent>
    @if (editLead is not null)
    {
        <div class="space-y-4">
            <div class="grid grid-cols-2 gap-3">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">First Name</label>
                    <input @bind="editLead.FirstName" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Last Name</label>
                    <input @bind="editLead.LastName" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" />
                </div>
            </div>
            <div class="grid grid-cols-2 gap-3">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Email</label>
                    <input @bind="editLead.Email" type="email" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Phone</label>
                    <input @bind="editLead.Phone" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" />
                </div>
            </div>
            <div class="grid grid-cols-2 gap-3">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Company</label>
                    <input @bind="editLead.Company" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Job Title</label>
                    <input @bind="editLead.JobTitle" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" />
                </div>
            </div>
            <div class="grid grid-cols-2 gap-3">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Source</label>
                    <select @bind="editLead.SourceStr" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm">
                        <option>Website</option><option>Referral</option><option>Email</option><option>Phone</option><option>Social</option><option>Event</option><option>Other</option>
                    </select>
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Est. Value</label>
                    <input type="number" @bind="editLead.EstimatedValue" step="100" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" />
                </div>
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Notes</label>
                <textarea @bind="editLead.Notes" rows="2" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm"></textarea>
            </div>
        </div>
    }
    </ChildContent>
    <Footer>
        <button @onclick="SaveLead" class="px-4 py-2 bg-indigo-600 text-white rounded-lg text-sm font-medium hover:bg-indigo-700">Save</button>
        <button @onclick="() => showLeadModal = false" class="px-4 py-2 border border-gray-300 rounded-lg text-sm hover:bg-gray-50">Cancel</button>
    </Footer>
</Modal>

