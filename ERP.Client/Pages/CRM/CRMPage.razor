@* Opportunity Modal *@
<Modal IsVisible="showOppModal" Title='@(editOpportunity?.Id > 0 ? "Edit Opportunity" : "New Opportunity")' OnClose="() => showOppModal = false">
    <ChildContent>
    @if (editOpportunity is not null)
    {
        <div class="space-y-4">
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Opportunity Name</label>
                <input @bind="editOpportunity.Name" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" />
            </div>
            <div class="grid grid-cols-2 gap-3">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Amount</label>
                    <input type="number" @bind="editOpportunity.Amount" step="100" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Probability (%)</label>
                    <input type="number" @bind="editOpportunity.Probability" min="0" max="100" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" />
                </div>
            </div>
            <div class="grid grid-cols-2 gap-3">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Stage</label>
                    <select @bind="editOpportunity.StageStr" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm">
                        <option>Prospecting</option><option>Qualification</option><option>Proposal</option><option>Negotiation</option><option>ClosedWon</option><option>ClosedLost</option>
                    </select>
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Close Date</label>
                    <input type="date" @bind="editOpportunity.CloseDate" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" />
                </div>
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Description</label>
                <textarea @bind="editOpportunity.Description" rows="2" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm"></textarea>
            </div>
        </div>
    }
    </ChildContent>
    <Footer>
        <button @onclick="SaveOpportunity" class="px-4 py-2 bg-indigo-600 text-white rounded-lg text-sm font-medium hover:bg-indigo-700">Save</button>
        <button @onclick="() => showOppModal = false" class="px-4 py-2 border border-gray-300 rounded-lg text-sm hover:bg-gray-50">Cancel</button>
    </Footer>
</Modal>

@code {
    private string activeTab = "Leads";
    private readonly Dictionary<string, string> tabs = new()
    {
        ["Leads"]         = "person_search",
        ["Contacts"]      = "contacts",
        ["Opportunities"] = "trending_up",
        ["Pipeline"]      = "view_kanban"
    };

    private PagedResult<LeadDto>? leads;
    private string search = "";
    private int leadPage = 1, leadPageSize = 10;
    private bool showLeadModal;
    private LeadEditModel? editLead;

    private PagedResult<ContactDto>? contacts;
    private int contactPage = 1, contactPageSize = 10;
    private bool showContactModal;
    private ContactEditModel? editContact;

    private PagedResult<OpportunityDto>? opportunities;
    private int oppPage = 1, oppPageSize = 10;
    private bool showOppModal;
    private OpportunityEditModel? editOpportunity;

    private List<PipelineStageDto>? pipeline;

    protected override async Task OnInitializedAsync() => await LoadTab();

    private async Task LoadTab()
    {
        switch (activeTab)
        {
            case "Leads":         await LoadLeads(); break;
            case "Contacts":      await LoadContacts(); break;
            case "Opportunities": await LoadOpportunities(); break;
            case "Pipeline":      await LoadPipeline(); break;
        }
    }

    private async Task LoadLeads()
    {
        var r = await Api.GetAsync<ApiResponse<PagedResult<LeadDto>>>($"/api/leads?page={leadPage}&pageSize={leadPageSize}&search={search}");
        leads = r?.Data;
    }

    private async Task LoadContacts()
    {
        var r = await Api.GetAsync<ApiResponse<PagedResult<ContactDto>>>($"/api/contacts?page={contactPage}&pageSize={contactPageSize}&search={search}");
        contacts = r?.Data;
    }

    private async Task LoadOpportunities()
    {
        var r = await Api.GetAsync<ApiResponse<PagedResult<OpportunityDto>>>($"/api/opportunities?page={oppPage}&pageSize={oppPageSize}");
        opportunities = r?.Data;
    }

    private async Task LoadPipeline()
    {
        var r = await Api.GetAsync<ApiResponse<List<PipelineStageDto>>>("/api/pipeline");
        pipeline = r?.Data;
    }

    private void OnSearch(KeyboardEventArgs e) { if (e.Key == "Enter") _ = LoadLeads(); }

    private void ShowLeadModal(LeadDto? l = null)
    {
        editLead = l is null ? new LeadEditModel() : new LeadEditModel { Id = l.Id, FirstName = l.FirstName, LastName = l.LastName, Email = l.Email, Phone = l.Phone, Company = l.Company, JobTitle = l.JobTitle, SourceStr = l.Source.ToString(), EstimatedValue = l.EstimatedValue, Notes = l.Notes };
        showLeadModal = true;
    }

    private async Task SaveLead()
    {
        if (editLead is null) return;
        var dto = new LeadDto { Id = editLead.Id, FirstName = editLead.FirstName, LastName = editLead.LastName, Email = editLead.Email, Phone = editLead.Phone, Company = editLead.Company, JobTitle = editLead.JobTitle, EstimatedValue = editLead.EstimatedValue, Notes = editLead.Notes, Source = Enum.TryParse<LeadSource>(editLead.SourceStr, out var src) ? src : LeadSource.Website };
        if (editLead.Id == 0) await Api.PostAsync<LeadDto, ApiResponse<LeadDto>>("/api/leads", dto);
        else await Api.PutAsync<LeadDto, ApiResponse<LeadDto>>($"/api/leads/{editLead.Id}", dto);
        showLeadModal = false;
        await LoadLeads();
    }

    private void ShowContactModal(ContactDto? c = null)
    {
        editContact = c is null ? new ContactEditModel() : new ContactEditModel { Id = c.Id, FirstName = c.FirstName, LastName = c.LastName, Email = c.Email, Phone = c.Phone, Company = c.Company, JobTitle = c.JobTitle, City = c.City, Country = c.Country };
        showContactModal = true;
    }

    private async Task SaveContact()
    {
        if (editContact is null) return;
        var dto = new ContactDto { Id = editContact.Id, FirstName = editContact.FirstName, LastName = editContact.LastName, Email = editContact.Email, Phone = editContact.Phone, Company = editContact.Company, JobTitle = editContact.JobTitle, City = editContact.City, Country = editContact.Country };
        if (editContact.Id == 0) await Api.PostAsync<ContactDto, ApiResponse<ContactDto>>("/api/contacts", dto);
        else await Api.PutAsync<ContactDto, ApiResponse<ContactDto>>($"/api/contacts/{editContact.Id}", dto);
        showContactModal = false;
        await LoadContacts();
    }

    private void ShowOpportunityModal(OpportunityDto? o = null)
    {
        editOpportunity = o is null ? new OpportunityEditModel { CloseDate = DateTime.Today.AddDays(30) } : new OpportunityEditModel { Id = o.Id, Name = o.Name, Amount = o.Amount, Probability = o.Probability, StageStr = o.Stage.ToString(), CloseDate = o.CloseDate ?? DateTime.Today.AddDays(30), Description = o.Description };
        showOppModal = true;
    }

    private async Task SaveOpportunity()
    {
        if (editOpportunity is null) return;
        var dto = new OpportunityDto { Id = editOpportunity.Id, Name = editOpportunity.Name, Amount = editOpportunity.Amount, Probability = editOpportunity.Probability, ExpectedRevenue = editOpportunity.Amount * editOpportunity.Probability / 100, CloseDate = editOpportunity.CloseDate, Description = editOpportunity.Description, Stage = Enum.TryParse<OpportunityStage>(editOpportunity.StageStr, out var st) ? st : OpportunityStage.Prospecting };
        if (editOpportunity.Id == 0) await Api.PostAsync<OpportunityDto, ApiResponse<OpportunityDto>>("/api/opportunities", dto);
        else await Api.PutAsync<OpportunityDto, ApiResponse<OpportunityDto>>($"/api/opportunities/{editOpportunity.Id}", dto);
        showOppModal = false;
        await LoadOpportunities();
    }

    private static string LeadStatusColor(string s) => s switch
    {
        "Won"         => "bg-green-100 text-green-700",
        "Qualified"   => "bg-blue-100 text-blue-700",
        "Contacted"   => "bg-teal-100 text-teal-700",
        "Proposal"    => "bg-purple-100 text-purple-700",
        "Negotiation" => "bg-yellow-100 text-yellow-700",
        "New"         => "bg-gray-100 text-gray-600",
        "Lost"        => "bg-red-100 text-red-600",
        _             => "bg-gray-100 text-gray-600"
    };

    private static string OpportunityStageColor(string s) => s switch
    {
        "ClosedWon"     => "bg-green-100 text-green-700",
        "ClosedLost"    => "bg-red-100 text-red-600",
        "Negotiation"   => "bg-orange-100 text-orange-700",
        "Proposal"      => "bg-purple-100 text-purple-700",
        "Qualification" => "bg-blue-100 text-blue-700",
        "Prospecting"   => "bg-gray-100 text-gray-600",
        _               => "bg-gray-100 text-gray-600"
    };

